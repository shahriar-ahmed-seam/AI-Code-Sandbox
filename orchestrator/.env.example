# Internal URL of the Sandbox Runner (never public).
SANDBOX_URL=http://localhost:8090

# API key required for /api/v1/execute. Leave empty to run in open/dev mode.
API_KEY=

# CORS — comma-separated allowed origins, or "*".
ALLOWED_ORIGINS=*

# Rate limiting (token bucket) per client identity.
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20

# Input bounds.
MAX_CODE_BYTES=65536
DEFAULT_TIMEOUT_MS=8000
MAX_TIMEOUT_MS=20000
