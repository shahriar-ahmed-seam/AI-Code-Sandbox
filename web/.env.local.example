# Base URL of the Orchestrator API (no trailing slash).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional API key. Leave empty when the orchestrator runs in open/dev mode.
NEXT_PUBLIC_API_KEY=

# --- AI code generation (server-side only; never prefix with NEXT_PUBLIC) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Comma-separated free models, tried in order until one succeeds.
OPENROUTER_MODELS=qwen/qwen3-coder:free,meta-llama/llama-3.3-70b-instruct:free
