FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/sandbox .

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=build /out/sandbox /usr/local/bin/sandbox
EXPOSE 8090
ENTRYPOINT ["sandbox"]
